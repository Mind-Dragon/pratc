# Ignore all dot directories by default (use ! to keep specific ones)
**/.*
!.gitignore
!.env.example

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
.claude/
*.swp
*.swo
*~

# Env / secrets
.env
.env.*
!.env.example
.envrc
.direnv/
*.local
*.pem
*.key
*.p12
*.pfx
*.crt
*.der

# Logs / temp
*.log
.cache/
tmp/
temp/
.tmp/

# Go
bin/
dist/
coverage.out
*.test
/pratc

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.venv/
venv/

# Node / web
node_modules/
.next/
.turbo/
coverage/
playwright-report/
test-results/
*.tsbuildinfo

# Build artifacts
build/
out/
*.sqlite
*.sqlite3
*.db
/--viewport

# Fixtures data (fetched via scripts/fetch_fixtures.py - keep script, ignore data)
fixtures/prs/
fixtures/cache/
fixtures/tmp/
fixtures/*.json

# Docker
.docker/

# Next.js generated
next-env.d.ts

# Bun lock (we use package-lock.json for reproducibility)
bun.lock
