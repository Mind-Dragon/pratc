!.env.example

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
.claude/
*.swp
*.swo
*~

# Env / secrets
.env
.env.*
!.env.example
.envrc
.direnv/
*.local
*.pem
*.key
*.p12
*.pfx
*.crt
*.der

# Logs / temp
*.log
.cache/
tmp/
temp/
.tmp/

# Go
bin/
dist/
coverage.out
*.test
/pratc

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.venv/
venv/

