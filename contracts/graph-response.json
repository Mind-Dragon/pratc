{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pratc.dev/contracts/graph-response.json",
  "title": "GraphResponse",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "repo": { "type": "string" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "nodes": {
      "type": "array",
      "items": { "$ref": "shared-definitions.json#/$defs/GraphNode" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "shared-definitions.json#/$defs/GraphEdge" }
    },
    "dot": { "type": "string", "minLength": 1 }
  },
  "required": ["repo", "generatedAt", "nodes", "edges", "dot"]
}
