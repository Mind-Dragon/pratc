{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pratc.dev/contracts/cluster-request.json",
  "title": "ClusterRequest",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "repo": { "type": "string" },
    "prs": {
      "type": "array",
      "items": { "$ref": "shared-definitions.json#/$defs/PR" }
    },
    "model": { "type": "string" },
    "minClusterSize": { "type": "integer", "minimum": 1 }
  },
  "required": ["repo", "prs", "model", "minClusterSize"]
}
