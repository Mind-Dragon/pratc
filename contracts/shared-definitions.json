{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://pratc.dev/contracts/shared-definitions.json",
    "title": "SharedDefinitions",
    "$defs": {
        "PR": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string"
                },
                "repo": {
                    "type": "string"
                },
                "number": {
                    "type": "integer"
                },
                "title": {
                    "type": "string"
                },
                "body": {
                    "type": "string"
                },
                "url": {
                    "type": "string",
                    "format": "uri"
                },
                "author": {
                    "type": "string"
                },
                "labels": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "files_changed": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "review_status": {
                    "type": "string"
                },
                "ci_status": {
                    "type": "string"
                },
                "mergeable": {
                    "type": "string"
                },
                "base_branch": {
                    "type": "string"
                },
                "head_branch": {
                    "type": "string"
                },
                "cluster_id": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "updated_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "is_draft": {
                    "type": "boolean"
                },
                "is_bot": {
                    "type": "boolean"
                },
                "additions": {
                    "type": "integer"
                },
                "deletions": {
                    "type": "integer"
                },
                "changed_files_count": {
                    "type": "integer"
                }
            },
            "required": [
                "id",
                "repo",
                "number",
                "title",
                "body",
                "url",
                "author",
                "labels",
                "files_changed",
                "review_status",
                "ci_status",
                "mergeable",
                "base_branch",
                "head_branch",
                "cluster_id",
                "created_at",
                "updated_at",
                "is_draft",
                "is_bot",
                "additions",
                "deletions",
                "changed_files_count"
            ]
        },
        "PRCluster": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "cluster_id": {
                    "type": "string"
                },
                "cluster_label": {
                    "type": "string"
                },
                "summary": {
                    "type": "string"
                },
                "pr_ids": {
                    "type": "array",
                    "items": {
                        "type": "integer"
                    }
                },
                "health_status": {
                    "type": "string"
                },
                "average_similarity": {
                    "type": "number"
                },
                "sample_titles": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "required": [
                "cluster_id",
                "cluster_label",
                "summary",
                "pr_ids",
                "health_status",
                "average_similarity",
                "sample_titles"
            ]
        },
        "DuplicateGroup": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "canonical_pr_number": {
                    "type": "integer"
                },
                "duplicate_pr_numbers": {
                    "type": "array",
                    "items": {
                        "type": "integer"
                    }
                },
                "similarity": {
                    "type": "number"
                },
                "reason": {
                    "type": "string"
                }
            },
            "required": [
                "canonical_pr_number",
                "duplicate_pr_numbers",
                "similarity",
                "reason"
            ]
        },
        "ConflictPair": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "source_pr": {
                    "type": "integer"
                },
                "target_pr": {
                    "type": "integer"
                },
                "conflict_type": {
                    "type": "string"
                },
                "files_touched": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "severity": {
                    "type": "string"
                },
                "reason": {
                    "type": "string"
                }
            },
            "required": [
                "source_pr",
                "target_pr",
                "conflict_type",
                "files_touched",
                "severity",
                "reason"
            ]
        },
        "StalenessReport": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "pr_number": {
                    "type": "integer"
                },
                "score": {
                    "type": "number"
                },
                "signals": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "reasons": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "superseded_by": {
                    "type": "array",
                    "items": {
                        "type": "integer"
                    }
                }
            },
            "required": [
                "pr_number",
                "score",
                "signals",
                "reasons",
                "superseded_by"
            ]
        },
        "MergePlanCandidate": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "pr_number": {
                    "type": "integer"
                },
                "title": {
                    "type": "string"
                },
                "score": {
                    "type": "number"
                },
                "rationale": {
                    "type": "string"
                },
                "files_touched": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "conflict_warnings": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "required": [
                "pr_number",
                "title",
                "score",
                "rationale",
                "files_touched",
                "conflict_warnings"
            ]
        },
        "MergePlan": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "plan_id": {
                    "type": "string"
                },
                "mode": {
                    "type": "string"
                },
                "formula_expression": {
                    "type": "string"
                },
                "selected": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/MergePlanCandidate"
                    }
                },
                "ordering": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/MergePlanCandidate"
                    }
                },
                "total_score": {
                    "type": "number"
                },
                "warnings": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "required": [
                "plan_id",
                "mode",
                "formula_expression",
                "selected",
                "ordering",
                "total_score",
                "warnings"
            ]
        },
        "GraphNode": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "pr_number": {
                    "type": "integer"
                },
                "title": {
                    "type": "string"
                },
                "cluster_id": {
                    "type": "string"
                },
                "ci_status": {
                    "type": "string"
                }
            },
            "required": [
                "pr_number",
                "title",
                "cluster_id",
                "ci_status"
            ]
        },
        "GraphEdge": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "from_pr": {
                    "type": "integer"
                },
                "to_pr": {
                    "type": "integer"
                },
                "edge_type": {
                    "type": "string"
                },
                "reason": {
                    "type": "string"
                }
            },
            "required": [
                "from_pr",
                "to_pr",
                "edge_type",
                "reason"
            ]
        },
        "Counts": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "total_prs": {
                    "type": "integer"
                },
                "cluster_count": {
                    "type": "integer"
                },
                "duplicate_groups": {
                    "type": "integer"
                },
                "overlap_groups": {
                    "type": "integer"
                },
                "conflict_pairs": {
                    "type": "integer"
                },
                "stale_prs": {
                    "type": "integer"
                }
            },
            "required": [
                "total_prs",
                "cluster_count",
                "duplicate_groups",
                "overlap_groups",
                "conflict_pairs",
                "stale_prs"
            ]
        },
        "Thresholds": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "duplicate": {
                    "type": "number"
                },
                "overlap": {
                    "type": "number"
                }
            },
            "required": [
                "duplicate",
                "overlap"
            ]
        },
        "PlanRejection": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "pr_number": {
                    "type": "integer"
                },
                "reason": {
                    "type": "string"
                }
            },
            "required": [
                "pr_number",
                "reason"
            ]
        },
        "ActionLane": {
            "type": "string",
            "enum": [
                "fast_merge",
                "fix_and_merge",
                "duplicate_close",
                "reject_or_close",
                "focused_review",
                "future_or_reengage",
                "human_escalate"
            ]
        },
        "PolicyProfile": {
            "type": "string",
            "enum": [
                "advisory",
                "guarded",
                "autonomous"
            ]
        },
        "ActionWorkItemState": {
            "type": "string",
            "enum": [
                "proposed",
                "claimable",
                "claimed",
                "preflighted",
                "patched",
                "tested",
                "approved_for_execution",
                "executed",
                "verified",
                "failed",
                "escalated",
                "canceled"
            ]
        },
        "ActionKind": {
            "type": "string",
            "enum": [
                "merge",
                "close",
                "comment",
                "label",
                "request_changes",
                "apply_fix"
            ]
        },
        "ActionPreflight": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "check": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                },
                "reason": {
                    "type": "string"
                },
                "evidence_refs": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "required": {
                    "type": "boolean"
                },
                "checked_at": {
                    "type": "string",
                    "format": "date-time"
                }
            },
            "required": [
                "check",
                "status",
                "reason",
                "evidence_refs",
                "required",
                "checked_at"
            ]
        },
        "ProofBundle": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string"
                },
                "work_item_id": {
                    "type": "string"
                },
                "pr_number": {
                    "type": "integer"
                },
                "summary": {
                    "type": "string"
                },
                "evidence_refs": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "artifact_refs": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "test_commands": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "test_results": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "created_by": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string",
                    "format": "date-time"
                }
            },
            "required": [
                "id",
                "work_item_id",
                "pr_number",
                "summary",
                "evidence_refs",
                "artifact_refs",
                "test_commands",
                "test_results",
                "created_by",
                "created_at"
            ]
        },
        "ActionLease": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "claimed_by": {
                    "type": "string"
                },
                "claimed_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "expires_at": {
                    "type": "string",
                    "format": "date-time"
                }
            },
            "required": []
        },
        "ActionWorkItem": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string"
                },
                "pr_number": {
                    "type": "integer"
                },
                "lane": {
                    "$ref": "#/$defs/ActionLane"
                },
                "state": {
                    "$ref": "#/$defs/ActionWorkItemState"
                },
                "priority_score": {
                    "type": "number"
                },
                "confidence": {
                    "type": "number"
                },
                "risk_flags": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "reason_trail": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "evidence_refs": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "required_preflight_checks": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/ActionPreflight"
                    }
                },
                "idempotency_key": {
                    "type": "string"
                },
                "lease_state": {
                    "$ref": "#/$defs/ActionLease"
                },
                "allowed_actions": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/ActionKind"
                    }
                },
                "blocked_reasons": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "proof_bundle_refs": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "required": [
                "id",
                "pr_number",
                "lane",
                "state",
                "priority_score",
                "confidence",
                "risk_flags",
                "reason_trail",
                "evidence_refs",
                "required_preflight_checks",
                "idempotency_key",
                "lease_state",
                "allowed_actions",
                "blocked_reasons"
            ]
        },
        "ActionIntent": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string"
                },
                "action": {
                    "$ref": "#/$defs/ActionKind"
                },
                "pr_number": {
                    "type": "integer"
                },
                "lane": {
                    "$ref": "#/$defs/ActionLane"
                },
                "dry_run": {
                    "type": "boolean"
                },
                "policy_profile": {
                    "$ref": "#/$defs/PolicyProfile"
                },
                "confidence": {
                    "type": "number"
                },
                "risk_flags": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "reasons": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "evidence_refs": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "preconditions": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/ActionPreflight"
                    }
                },
                "idempotency_key": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "payload": {
                    "type": "object",
                    "additionalProperties": true
                }
            },
            "required": [
                "id",
                "action",
                "pr_number",
                "lane",
                "dry_run",
                "policy_profile",
                "confidence",
                "risk_flags",
                "reasons",
                "evidence_refs",
                "preconditions",
                "idempotency_key",
                "created_at"
            ]
        },
        "ActionLaneSummary": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "lane": {
                    "$ref": "#/$defs/ActionLane"
                },
                "count": {
                    "type": "integer"
                },
                "work_item_ids": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "required": [
                "lane",
                "count",
                "work_item_ids"
            ]
        },
        "ActionCorpusSnapshot": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "total_prs": {
                    "type": "integer"
                },
                "head_sha_indexed": {
                    "type": "boolean"
                },
                "analysis_truncated": {
                    "type": "boolean"
                },
                "max_prs_applied": {
                    "type": "integer"
                }
            },
            "required": [
                "total_prs",
                "head_sha_indexed",
                "analysis_truncated",
                "max_prs_applied"
            ]
        },
        "ActionPlanAuditCheck": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "name": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                },
                "reason": {
                    "type": "string"
                },
                "evidence_refs": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "checked_at": {
                    "type": "string",
                    "format": "date-time"
                }
            },
            "required": [
                "name",
                "status"
            ]
        },
        "ActionPlanAudit": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "checks": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/ActionPlanAuditCheck"
                    }
                },
                "warnings": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "errors": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "required": [
                "checks"
            ]
        }
    }
}
