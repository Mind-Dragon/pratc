# prATC Environment Variables
# Copy to .env and fill in values. Never commit secrets.

# ── GitHub Authentication (required for live repo access) ─────────────
# Primary token. Used by the CLI and API service for GitHub GraphQL.
# Get one with: gh auth token
GH_TOKEN=

# Sync worker reads GITHUB_TOKEN directly (separate code path).
# In docker-compose, both GH_TOKEN and GITHUB_TOKEN are mapped from the
# same value. If you set GH_TOKEN here, also export it as GITHUB_TOKEN
# for sync to work:
#   GITHUB_TOKEN=${GH_TOKEN}
GITHUB_TOKEN=

# Secret-store fallback (psst). Checked before GH_TOKEN in app service.
# GITHUB_PAT=

# ── ML Backend ─────────────────────────────────────────────────────────
# Controls which ML provider the Go→Python bridge uses.
#   (empty or "local")  = local sklearn/tfidf (default, safe for live tests)
#   "voyage"            = Voyage AI embeddings (requires VOYAGE_API_KEY)
ML_BACKEND=local

# ── Database Paths ─────────────────────────────────────────────────────
# SQLite cache for PR data, sync jobs, audit log.
# PRATC_DB_PATH=~/.pratc/pratc.db

# SQLite store for settings (global/repo scope).
# PRATC_SETTINGS_DB=./pratc-settings.db

# ── Cache ──────────────────────────────────────────────────────────────
# How long cached data is considered fresh (Go duration syntax).
# PRATC_CACHE_TTL=1h

# Directory for git mirror clones.
# PRATC_CACHE_DIR=~/.pratc/mirrors

# ── Analysis ───────────────────────────────────────────────────────────
# PRATC_ANALYSIS_BACKEND=local

# ── Voyage AI (optional, for embedding-based ML) ──────────────────────
# VOYAGE_API_KEY=
# VOYAGE_MODEL=

# ── Web Dashboard ──────────────────────────────────────────────────────
# URL the Next.js frontend uses to reach the API server.
# NEXT_PUBLIC_PRATC_API_URL=http://localhost:8080

# ── Python ─────────────────────────────────────────────────────────────
# Set automatically by the ML bridge subprocess. Override only if needed.
# PYTHONPATH=ml-service/src
